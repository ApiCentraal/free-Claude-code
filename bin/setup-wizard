#!/usr/bin/env bash
# Claude Code Setup Wizard Launcher
# Usage: ./bin/setup-wizard

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Check for Python 3
if ! command -v python3 &> /dev/null; then
    echo "Error: Python 3 is required but not installed."
    exit 1
fi

# Run the wizard
cd "$PROJECT_ROOT"
python3 "$PROJECT_ROOT/setup_wizard.py" "$@"
